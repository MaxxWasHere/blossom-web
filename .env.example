# Base path for the static export.
#
# - Project Pages URL (https://maxxwashere.github.io/blossom-web):
#     NEXT_PUBLIC_BASE_PATH=/blossom-web
# - Custom domain / root (https://your-domain/):
#     NEXT_PUBLIC_BASE_PATH=
#
# The GitHub Actions workflow sets this for the project-pages build.
# For local dev, copy this file to ".env.local" and adjust as needed.
NEXT_PUBLIC_BASE_PATH=
